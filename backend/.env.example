# ============================================
# BACKEND - Variáveis de Ambiente
# ============================================

# Banco de dados (Railway fornece automaticamente quando você adiciona PostgreSQL)
DATABASE_URL="postgresql://usuario:senha@host:5432/banco"

# JWT - OBRIGATÓRIO: troque por uma string longa e aleatória em produção!
JWT_SECRET="troque_por_uma_string_muito_segura_em_producao_min_32_chars"
JWT_EXPIRES_IN="7d"

# Porta - Railway injeta automaticamente, NÃO defina manualmente no Railway
# PORT=3001

# Node environment
NODE_ENV="production"

# OpenAI (opcional - para o assistente de IA com GPT-4)
OPENAI_API_KEY="sk-sua-chave-openai-aqui"
